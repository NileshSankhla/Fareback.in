{
  "name": "fareback",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "email": "bunx --bun react-email dev --dir src/components/emails",
    "lint": "eslint src scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "load-test": "bun scripts/load-test.js",
    "load-test:quick": "bun scripts/load-test.js --url http://127.0.0.1:3000 --connections 50 --duration 20",
    "load-test:stress": "bun scripts/load-test.js --url http://127.0.0.1:3000 --connections 200 --duration 60",
    "db:push": "drizzle-kit push",
    "db:seed": "bun --env-file=.env --env-file=.env.local scripts/seed-merchants.mjs",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.11",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "@react-email/preview-server": "5.2.10",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.5.8",
    "react-email": "^5.2.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "ignoreScripts": [
    "sharp",
