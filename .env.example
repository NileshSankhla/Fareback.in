# Database
# Local development: uses the Docker Compose PostgreSQL container (see docker-compose.yml)
DATABASE_URL=postgresql://postgres:password@localhost:5432/my_modern_web
#
# Vercel + Neon production:
#
# DATABASE_URL — POOLED connection (PgBouncer).
# Used by the running Next.js app for all queries.
#   postgres://<user>:<password>@<region>-pooler.neon.tech/<dbname>?sslmode=require
#
# DATABASE_URL_UNPOOLED — DIRECT connection (no PgBouncer).
# Used by Drizzle Kit (db:push / db:migrate / db:studio) for schema migrations.
# Required because PgBouncer transaction mode can interfere with DDL statements.
#   postgres://<user>:<password>@<region>.neon.tech/<dbname>?sslmode=require
#
# In Vercel → Settings → Environment Variables set BOTH of the above.
DATABASE_URL_UNPOOLED=postgresql://postgres:password@localhost:5432/my_modern_web

# PostgreSQL (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=my_modern_web
POSTGRES_PORT=5432

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GITHUB_URL=https://github.com/NileshSankhla/my-modern-web
NEXT_PUBLIC_TWITTER_URL=https://twitter.com
ADMIN_EMAIL=you@example.com
# Optional comma-separated override
# ADMIN_EMAILS=you@example.com,coadmin@example.com

# Google OAuth (for Sign in with Google)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

