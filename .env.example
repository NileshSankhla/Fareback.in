# Database
# Neon only (no local Postgres)
# DATABASE_URL should be the pooled connection string (contains -pooler)
DATABASE_URL=postgresql://<user>:<password>@ep-xxx-pooler.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require
#
# Vercel + Neon production:
#
# DATABASE_URL — POOLED connection (PgBouncer).
# Used by the running Next.js app for all queries.
#   postgres://<user>:<password>@<region>-pooler.neon.tech/<dbname>?sslmode=require
#
# DATABASE_URL_UNPOOLED — DIRECT connection (no PgBouncer).
# Used by Drizzle Kit (db:push / db:migrate / db:studio) for schema migrations.
# Required because PgBouncer transaction mode can interfere with DDL statements.
#   postgres://<user>:<password>@<region>.neon.tech/<dbname>?sslmode=require
#
# In Vercel → Settings → Environment Variables set BOTH of the above.
#
# ⚠️  If you reset or rotate your Neon database password you MUST:
#   1. Copy the new connection strings from Neon dashboard → Connection Details.
#   2. Update DATABASE_URL and DATABASE_URL_UNPOOLED in Vercel → Settings → Environment Variables.
#   3. Trigger a redeployment so the new credentials are picked up.
#   Leaving the old password in Vercel will cause "password authentication failed" errors.
#
# DATABASE_URL_UNPOOLED should be the direct connection string (no -pooler)
DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@ep-xxx.<region>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# App Configuration
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (Vercel): set to your deployment URL, e.g.:
# NEXT_PUBLIC_APP_URL=https://fareback.in
NEXT_PUBLIC_GITHUB_URL=https://github.com/<your-username>/fareback
NEXT_PUBLIC_TWITTER_URL=https://twitter.com
ADMIN_EMAIL=nileshsankhlakgp@gmail.com
# Optional comma-separated override
# ADMIN_EMAILS=nileshsankhlakgp@gmail.com,coadmin@example.com

# Google OAuth (for Sign in with Google)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://fareback.in/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Upstash Redis (recommended for high-concurrency affiliate link rotation)
# Create a Redis database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
AFFILIATE_REDIS_LIST_KEY=affiliate:amazon:links

# Amazon affiliate base URL used when Excel rows contain only tag IDs.
# Keep all your affiliate params here (linkCode/linkId/ref/etc). The system only overrides `tag`.
AMAZON_AFFILIATE_BASE_URL=https://www.amazon.in?&linkCode=ll2&tag=fareback-21&linkId=711b78face92a1bf8be6139d25b1f780&ref_=as_li_ss_tl

